<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Circle background matching the Welcome Screen logo -->
    <!-- Centered at (54, 54) with a radius of 32 (diameter 64dp, which fits perfectly in the 72dp safe zone) -->
    <path
        android:pathData="M54,54m-32,0a32,32 0 1,1 64,0a32,32 0 1,1 -64,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="22"
                android:startY="22"
                android:endX="86"
                android:endY="86"
                android:type="linear">
                <!-- NeonGreen: #00FF88 -->
                <item android:offset="0" android:color="#FF00FF88" />
                <!-- ElectricBlue: #00E5FF -->
                <item android:offset="1" android:color="#FF00E5FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Centered Music Note matching Icons.Default.MusicNote -->
    <!-- Viewport is 24x24. Scale is 32/24 = 1.3333. Translate to (38, 38) to center it. -->
    <group
        android:translateX="38"
        android:translateY="38"
        android:scaleX="1.3333"
        android:scaleY="1.3333">
        <path
            android:fillColor="#000000"
            android:pathData="M12,3v10.55c-0.59,-0.34 -1.27,-0.55 -2,-0.55 -2.21,0 -4,1.79 -4,4s1.79,4 4,4 4,-1.79 4,-4V7h4V3h-6z" />
    </group>
</vector>
